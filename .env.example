# Hugging Face token — required for hf-papers (authenticated API),
# hf-docs (fetching private/gated docs), hf-datasets, hf-jobs, hf-repos.
# Create at: https://huggingface.co/settings/tokens
HF_TOKEN=

# GitHub personal access token — required for github-code scripts.
# Fine-grained token with "Contents: Read" on public repos is enough.
# Create at: https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=

# Semantic Scholar API key — optional. Without it, S2 endpoints still work
# (public rate limits apply). With it, rate limits are raised.
# Request at: https://www.semanticscholar.org/product/api#api-key
S2_API_KEY=
